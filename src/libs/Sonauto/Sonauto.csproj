<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <NoWarn>$(NoWarn);CS3002;CS3003;CS1591;CA1822</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="Nuget">
    <Description>C# SDK for Sonauto (Melodia) -- fast AI song generation with lyrics and streaming playback.</Description>
    <PackageTags>api;client;sdk;dotnet;openapi;sonauto;ai;music-generation;song-generation;suno-alternative</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.4.1" />
  </ItemGroup>

</Project>
